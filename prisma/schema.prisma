// ======================================================
// Generator
// ======================================================

generator client {
  provider = "prisma-client-js"
}

// ======================================================
// Datasource
// ======================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// Enums
// ======================================================

enum UserRole {
  USER
  UMKM
  ADMIN
}

enum ActivityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationMethod {
  MANUAL
  AI
}

enum PointTransactionType {
  EARN
  REDEEM
  BONUS
  PENALTY
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  EVENT
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ParticipantStatus {
  JOINED
  COMPLETED
  FAILED
}

// ======================================================
// Models
// ======================================================

// User

model User {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(100)
  username        String    @unique @db.VarChar(50)
  email           String    @unique @db.VarChar(255)
  passwordHash    String?   @db.VarChar(255)
  role            UserRole  @default(USER)
  profileImageUrl String?   @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  totalPoint      Int       @default(0)
  trustScore      Int       @default(0)
  emailVerified   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  accounts              Account[]
  sessions              Session[]
  activities            Activity[]
  pointHistories        PointHistory[]
  verifications         ActivityVerification[]
  challengeParticipants ChallengeParticipant[]
  challengeProgresses   ChallengeProgress[]

  @@index([username])
  @@index([name])
  @@map("users")
}

model ActivityCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(100)
  description String? @db.Text
  pointReward Int
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@map("activity_categories")
}

model Activity {
  id String @id @default(uuid()) @db.Uuid

  userId     String @db.Uuid
  categoryId String @db.Uuid

  title       String  @db.VarChar(150)
  description String? @db.Text

  activityDate DateTime

  status ActivityStatus @default(PENDING)

  adminNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category ActivityCategory @relation(fields: [categoryId], references: [id])

  photos ActivityPhoto[]

  verification ActivityVerification?

  pointHistory PointHistory?

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([activityDate])
  @@map("activities")
}

model ActivityPhoto {
  id String @id @default(uuid()) @db.Uuid

  activityId String @db.Uuid

  imageUrl String @db.VarChar(255)

  uploadedAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("activity_photos")
}

model ActivityVerification {
  id String @id @default(uuid()) @db.Uuid

  activityId String @unique @db.Uuid

  verifiedBy String @db.Uuid

  method VerificationMethod

  confidence Decimal? @db.Decimal(5, 2)

  note String? @db.Text

  verifiedAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  verifier User @relation(fields: [verifiedBy], references: [id])

  @@index([verifiedBy])
  @@map("activity_verifications")
}

model PointHistory {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid

  activityId String? @unique @db.Uuid

  type PointTransactionType

  point Int

  description String? @db.Text

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activity Activity? @relation(fields: [activityId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("point_histories")
}

model ChallengeCategory {
  id String @id @default(uuid()) @db.Uuid

  name        String  @db.VarChar(100)
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challenges Challenge[]

  @@index([name])
  @@map("challenge_categories")
}

model Challenge {
  id String @id @default(uuid()) @db.Uuid

  categoryId String @db.Uuid

  title String @db.VarChar(150)

  description String? @db.Text

  type ChallengeType

  target Int

  pointReward Int

  startDate DateTime

  endDate DateTime

  status ChallengeStatus @default(DRAFT)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  category ChallengeCategory @relation(fields: [categoryId], references: [id])

  participants ChallengeParticipant[]

  progresses ChallengeProgress[]

  @@index([categoryId])
  @@index([type])
  @@index([status])
  @@map("challenges")
}

model ChallengeParticipant {
  id String @id @default(uuid()) @db.Uuid

  challengeId String @db.Uuid

  userId String @db.Uuid

  status ParticipantStatus @default(JOINED)

  joinedAt DateTime @default(now())

  completedAt DateTime?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([challengeId, userId])
  @@index([userId])
  @@index([status])
  @@map("challenge_participants")
}

model ChallengeProgress {
  id String @id @default(uuid()) @db.Uuid

  challengeId String @db.Uuid

  userId String @db.Uuid

  currentValue Int @default(0)

  targetValue Int

  progressPercent Decimal @default(0) @db.Decimal(5, 2)

  updatedAt DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([challengeId, userId])
  @@index([userId])
  @@map("challenge_progresses")
}

// Account

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Session

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Verification Token

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
